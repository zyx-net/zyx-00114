      "id": "d44c751c-7a13-4614-9a74-b353f0bb227a",
      "title": "信息安全管理制度",
      "currentVersionId": "e5afbfaf-1986-47f0-afba-ba37f4b0d4a6",
      "createdBy": "命令行测试",
      "createdAt": "2026-06-16T18:18:55.907Z"
